# ============================================================
#  Artistry Gaming – Streamerübersicht  ·  Konfiguration
#  Diese Datei nach ".env" kopieren und Werte eintragen.
#  Die .env NIEMALS in ein öffentliches Repo committen!
# ============================================================

# --- Twitch (Pflicht für Live-Daten) ---
# Aus https://dev.twitch.tv/console/apps  →  App  →  Manage
TWITCH_CLIENT_ID=deine_client_id
TWITCH_CLIENT_SECRET=dein_client_secret

# --- Server ---
PORT=3000

# --- Spielerzahl (optional) ---
# Empfohlen: Cfx.re Join-Code aus cfx.re/join/XXXXXX
# (nur den Code "XXXXXX" oder die ganze URL eintragen)
CFX_JOIN=

# --- FiveM (optional, für echte Spielerzahl) ---
# Leer lassen, wenn nicht gewünscht. Beispiel: http://123.45.67.89:30120
FIVEM_ENDPOINT=
PLAYERS_MAX=256
